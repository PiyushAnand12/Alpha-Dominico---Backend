# ─────────────────────────────────────────────────────────────────────
#  SEPA Screener v2 — Configuration
#  Copy this file to  .env  and fill in your values
#  NEVER share or commit your .env file to GitHub
# ─────────────────────────────────────────────────────────────────────

# ── Email (Gmail) ──────────────────────────────────────────────────
# The Gmail address that will SEND the report
EMAIL_SENDER=your_email@gmail.com

# Gmail "App Password" — NOT your normal Gmail password
# How to get it: Gmail → Settings → Security → 2-Step Verification ON
# → App Passwords → Create → name it "Screener" → copy the 16-char code
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# The email address that will RECEIVE the report (can be same as sender)
EMAIL_TO=your_email@gmail.com

# ── Telegram (optional — leave blank to skip) ──────────────────────
# Create a bot at https://t.me/BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID
# Get it: message @userinfobot in Telegram → it replies with your chat ID
TELEGRAM_CHAT_ID=

# ── Screening thresholds (optional — defaults shown) ───────────────
# Minimum stock price (USD)
MIN_PRICE=5.0

# Minimum average daily volume (shares)
MIN_AVG_VOL=100000

# Minimum RS rank (0-100 percentile). 70 = top 30% of all stocks
RS_RANK_MIN=70

# Stock must be at least this % above its 52-week low
PCT_ABOVE_52WL=30.0

# Stock must be within this % of its 52-week high
PCT_FROM_52WH=25.0

# Minimum quarterly EPS growth (year-over-year %)
EPS_GROWTH_MIN=20.0

# Minimum quarterly revenue growth (year-over-year %)
REV_GROWTH_MIN=15.0

# ── Performance tuning ─────────────────────────────────────────────
# How many stocks to download per batch (lower = safer, slower)
BATCH_SIZE=150

# Seconds to sleep between batches (reduces rate-limit errors)
BATCH_SLEEP=2.0

# For QUICK TESTING: limit to first N tickers. Set 0 for full run.
MAX_TICKERS=0

# Where to save the HTML report and log file (default = current folder)
OUTPUT_DIR=.
